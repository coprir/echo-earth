# ECHO EARTH — environment keys
# Everything works WITHOUT keys (demo mode: synthetic weather + echo-grown city).
# Add keys to bring the real world in.

# Google Maps Platform — enable "Places API (New)" and "Maps JavaScript API"
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# OpenWeather — free tier is fine (https://openweathermap.org/api)
OPENWEATHER_API_KEY=

# Supabase — for cross-device memory, saved places, AI suggestions (optional)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — for the LLM recommendation layer (optional)
ANTHROPIC_API_KEY=
